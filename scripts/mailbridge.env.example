# Mission email channel config (constitution §12) — copy to ~/.claude/mailbridge.env
# (machine-local, gitignored, NEVER committed). Deploy copies this template to ~/.claude/scripts/.
#
# Reuse the dedicated bot Gmail proven in plaid-finance (already warmed; sends + receives). Gmail
# needs an App Password (2-Step Verification on the bot account).
SMTP_USER=yiliangs.work@gmail.com
SMTP_APP_PASSWORD=

# Reports / walk-throughs / proposals go here, AND this is the ONLY address allowed to send feedback.
REPORT_TO=yiliangsh@gmail.com

# Shared secret a reply must echo to authorize a GRANT-level action (amendment apply, docs/evolve.md). Pick something
# only you know. Without it in the reply, an authenticated reply can only RECORD verdicts into
# telemetry — never apply a constitution amendment. This is what enforces the §9 perimeter over email.
GRANT_SECRET=

# Repos the inbound router writes to (defaults shown; uncomment to override your layout).
# FIELDNOTES_DIR=C:\Users\Yiliang.Shao\source\repos\claude-fieldnotes
# LMO_DIR=C:\Users\Yiliang.Shao\source\repos\long-mission-orchestrator

# Optional.
# COMMAND_FROM=yiliangsh@gmail.com          # allow feedback from a different address than REPORT_TO
# INBOX_REQUIRE_ISSUED=1                     # set 0 only if your provider rewrites Message-IDs
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
